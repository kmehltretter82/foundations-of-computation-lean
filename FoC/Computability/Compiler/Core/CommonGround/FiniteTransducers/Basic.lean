theorem boolOutputDescription_haltsFrom_FSTSourceTape
    (out : Bool) (input : Word Bool) (leftScratch : Nat) :
    (BoolOutputDescription out).HaltsFromTape
      (FSTSourceTape input leftScratch)
      (FSTConstantBitTargetTape out input leftScratch) := by
  refine ⟨input.length + 1, ?_⟩
  have hrun :=
    boolOutputDescription_run_to_blank_tapeAtCells out input
      (List.replicate leftScratch (none : Option Bool)) []
  constructor
  · simpa [FSTSourceTape, FSTConstantBitTargetTape,
      FSTErasedSourceTargetTape, List.append_assoc] using
      congrArg MachineDescription.Configuration.state hrun
  · simpa [FSTSourceTape, FSTConstantBitTargetTape,
      FSTErasedSourceTargetTape, List.append_assoc] using
      congrArg MachineDescription.Configuration.tape hrun

/--
The first generated erasing-emitter description.  It is produced from the FST
transition rows rather than named directly as {name}`BoolOutputDescription`.
-/
def generatedConstantBitDescription (out : Bool) : MachineDescription :=
  (constantBitTransducer out).eraseThenEmitBitDescription

theorem generatedConstantBitDescription_eq_boolOutput
    (out : Bool) :
    generatedConstantBitDescription out = BoolOutputDescription out := by
  cases out <;> native_decide

theorem generatedConstantBitDescription_wellFormed
    (out : Bool) :
    (generatedConstantBitDescription out).WellFormed := by
  rw [generatedConstantBitDescription_eq_boolOutput]
  exact boolOutputDescription_wellFormed out

theorem generatedConstantBitDescription_haltTransitionFree
    (out : Bool) :
    (generatedConstantBitDescription out).HaltTransitionFree := by
  rw [generatedConstantBitDescription_eq_boolOutput]
  exact boolOutputDescription_haltTransitionFree out

theorem generatedConstantBitDescription_subroutineReady
    (out : Bool) :
    (generatedConstantBitDescription out).SubroutineReady :=
  ⟨generatedConstantBitDescription_wellFormed out,
    generatedConstantBitDescription_haltTransitionFree out⟩

theorem generatedConstantBitDescription_haltsFrom_FSTSourceTape
    (out : Bool) (input : Word Bool) (leftScratch : Nat) :
    (generatedConstantBitDescription out).HaltsFromTape
      (FSTSourceTape input leftScratch)
      (FSTConstantBitTargetTape out input leftScratch) := by
  rw [generatedConstantBitDescription_eq_boolOutput]
  exact boolOutputDescription_haltsFrom_FSTSourceTape
    out input leftScratch

/--
Target-parameterized exact realization contract for finite transducers.  This
is the general shape used while the framework grows multiple concrete physical
tape layouts.
-/
def ExactCompiledByDescription
    (F : FiniteTransducer) (D : MachineDescription)
    (targetTape : Word Bool -> Word Bool -> Nat -> Tape Bool) : Prop :=
  D.SubroutineReady ∧
    forall input output : Word Bool,
    forall leftScratch : Nat,
      F.RunsToOutput input output ->
        D.HaltsFromTape
          (FSTSourceTape input leftScratch)
          (targetTape input output leftScratch)

theorem constantBitTransducer_compiledByBoolOutputDescription
    (out : Bool) :
    ExactCompiledByDescription
      (constantBitTransducer out)
      (BoolOutputDescription out)
      FSTErasedSourceTargetTape := by
  constructor
  · exact boolOutputDescription_subroutineReady out
  · intro input output leftScratch hrun
    have hout := constantBitTransducer_run out input
    change
      (constantBitTransducer out).runFromStart
          (input.length + 1) input =
        some ((constantBitTransducer out).halt, output) at hrun
    rw [hout] at hrun
    cases hrun
    exact boolOutputDescription_haltsFrom_FSTSourceTape
      out input leftScratch

theorem constantBitTransducer_compiledByGeneratedDescription
    (out : Bool) :
    ExactCompiledByDescription
      (constantBitTransducer out)
      (generatedConstantBitDescription out)
      FSTErasedSourceTargetTape := by
  constructor
  · exact generatedConstantBitDescription_subroutineReady out
  · intro input output leftScratch hrun
    have hout := constantBitTransducer_run out input
    change
      (constantBitTransducer out).runFromStart
          (input.length + 1) input =
        some ((constantBitTransducer out).halt, output) at hrun
    rw [hout] at hrun
    cases hrun
    exact generatedConstantBitDescription_haltsFrom_FSTSourceTape
      out input leftScratch

